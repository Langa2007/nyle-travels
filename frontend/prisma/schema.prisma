generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email                String    @unique @db.VarChar(255)
  phone                String?   @unique @db.VarChar(50)
  password_hash        String?   @db.VarChar(255) // Optional for Google Login users
  first_name           String    @map("first_name") @db.VarChar(100)
  last_name            String    @map("last_name") @db.VarChar(100)
  date_of_birth        DateTime? @db.Date
  nationality          String?   @db.VarChar(100)
  passport_number      String?   @db.VarChar(50)
  passport_expiry      DateTime? @db.Date
  image                String?   @map("profile_image") @db.VarChar(500)
  role                String?   @default("user") @db.VarChar(50)
  emailVerified        Boolean?  @default(false) @map("email_verified")
  phone_verified       Boolean?  @default(false)
  two_factor_enabled    Boolean?  @default(false)
  two_factor_secret     String?   @db.Text
  refresh_token        String?   @db.Text
  password_reset_token  String?   @db.Text
  password_reset_expires DateTime? @db.Timestamp(6)
  email_verification_token String? @db.Text
  last_login           DateTime? @db.Timestamp(6)
  preferences          Json?     @default("{}")
  created_at           DateTime? @default(now()) @db.Timestamp(6)
  updated_at           DateTime? @default(now()) @db.Timestamp(6)
  deleted_at           DateTime? @db.Timestamp(6)

  @@map("users")
}

model AppSetting {
  key        String   @id @db.VarChar(255)
  value      Json     @db.JsonB
  updated_at DateTime @default(now()) @db.Timestamp(6)

  @@map("app_settings")
}

model Subscriber {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email      String   @unique @db.VarChar(255)
  status     String?  @default("active") @db.VarChar(50)
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)

  @@map("subscribers")
}

model Destination {
  id                  String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                String   @db.VarChar(255)
  slug                String   @unique @db.VarChar(255)
  country             String   @db.VarChar(100)
  region              String?  @db.VarChar(100)
  description         String?  @db.Text
  short_description   String?  @db.VarChar(500)
  latitude            Decimal? @db.Decimal(10, 8)
  longitude           Decimal? @db.Decimal(11, 8)
  best_time_to_visit  String?  @db.Text
  how_to_get_there    String?  @db.Text
  visa_requirements   String?  @db.Text
  health_safety       String?  @db.Text
  currency            String?  @db.VarChar(50)
  languages           String[]
  timezone            String?  @db.VarChar(100)
  featured_image      String?  @db.VarChar(500)
  gallery_images      String[]
  meta_title          String?  @db.VarChar(255)
  meta_description    String?  @db.Text
  meta_keywords       String[]
  is_featured         Boolean? @default(false)
  is_active           Boolean? @default(true)
  views_count         Int?     @default(0)
  created_at          DateTime @default(now()) @db.Timestamp(6)
  updated_at          DateTime @default(now()) @db.Timestamp(6)

  @@map("destinations")
}
