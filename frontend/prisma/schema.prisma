generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email                    String          @unique @db.VarChar(255)
  phone                    String?         @unique @db.VarChar(50)
  password_hash            String?         @db.VarChar(255)
  first_name               String          @map("first_name") @db.VarChar(100)
  last_name                String          @map("last_name") @db.VarChar(100)
  date_of_birth            DateTime?       @db.Date
  nationality              String?         @db.VarChar(100)
  passport_number          String?         @db.VarChar(50)
  passport_expiry          DateTime?       @db.Date
  image                    String?         @map("profile_image") @db.VarChar(500)
  role                     String?         @default("user") @db.VarChar(50)
  phone_verified           Boolean?        @default(false)
  two_factor_enabled       Boolean?        @default(false)
  two_factor_secret        String?
  refresh_token            String?
  password_reset_token     String?
  password_reset_expires   DateTime?
  email_verification_token String?
  last_login               DateTime?
  preferences              Json?           @default("{}")
  created_at               DateTime        @default(now())
  updated_at               DateTime        @default(now())
  deleted_at               DateTime?
  emailVerified            Boolean?        @default(false) @map("email_verified")
  admin_logs               admin_logs[]
  bookings                 bookings[]
  payments                 payments[]
  reviews                  reviews[]
  user_activity            user_activity[]

  @@map("users")
}

model AppSetting {
  key        String   @id @db.VarChar(255)
  value      Json
  updated_at DateTime @default(now())

  @@map("app_settings")
}

model Subscriber {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email      String   @unique @db.VarChar(255)
  status     String   @default("active") @db.VarChar(50)
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  @@map("subscribers")
}

model Destination {
  id                 String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name               String          @db.VarChar(255)
  slug               String          @unique @db.VarChar(255)
  country            String          @db.VarChar(100)
  region             String?         @db.VarChar(100)
  description        String?
  short_description  String?         @db.VarChar(500)
  latitude           Decimal?        @db.Decimal(10, 8)
  longitude          Decimal?        @db.Decimal(11, 8)
  best_time_to_visit String?
  how_to_get_there   String?
  visa_requirements  String?
  health_safety      String?
  currency           String?         @db.VarChar(50)
  languages          String[]
  timezone           String?         @db.VarChar(100)
  featured_image     String?         @db.VarChar(500)
  gallery_images     String[]
  meta_title         String?         @db.VarChar(255)
  meta_description   String?
  meta_keywords      String[]
  is_featured        Boolean         @default(false)
  is_active          Boolean         @default(true)
  views_count        Int             @default(0)
  created_at         DateTime        @default(now())
  updated_at         DateTime        @default(now())
  hotels             hotels[]
  tour_packages      tour_packages[]

  @@map("destinations")
}

model admin_logs {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  admin_id   String?  @db.Uuid
  action     String   @db.VarChar(100)
  details    Json?
  created_at DateTime @default(now())
  users      User?    @relation(fields: [admin_id], references: [id])
}

model booking_participants {
  id                   String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  booking_id           String?   @db.Uuid
  full_name            String    @db.VarChar(255)
  passport_number      String?   @db.VarChar(50)
  nationality          String?   @db.VarChar(100)
  date_of_birth        DateTime? @db.Date
  special_requirements String?
  created_at           DateTime  @default(now())
  bookings             bookings? @relation(fields: [booking_id], references: [id], onDelete: Cascade)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model bookings {
  id                         String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  booking_number             String                 @unique @db.VarChar(50)
  user_id                    String?                @db.Uuid
  tour_package_id            String?                @db.Uuid
  booking_date               DateTime               @default(now())
  start_date                 DateTime               @db.Date
  end_date                   DateTime               @db.Date
  number_of_adults           Int
  number_of_children         Int                    @default(0)
  children_ages              Int[]
  special_requests           String?
  dietary_requirements       String?
  medical_conditions         String?
  emergency_contact_name     String?                @db.VarChar(255)
  emergency_contact_phone    String?                @db.VarChar(50)
  emergency_contact_relation String?                @db.VarChar(100)
  subtotal_amount            Decimal                @db.Decimal(10, 2)
  tax_amount                 Decimal                @default(0) @db.Decimal(10, 2)
  discount_amount            Decimal                @default(0) @db.Decimal(10, 2)
  total_amount               Decimal                @db.Decimal(10, 2)
  currency                   String                 @default("KES") @db.VarChar(3)
  payment_status             String                 @default("unpaid") @db.VarChar(50)
  created_at                 DateTime               @default(now())
  updated_at                 DateTime               @default(now())
  status                     String                 @default("pending") @db.VarChar(50)
  booking_participants       booking_participants[]
  tour_packages              tour_packages?         @relation(fields: [tour_package_id], references: [id])
  users                      User?                  @relation(fields: [user_id], references: [id])
  payments                   payments[]
}

model contacts {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name       String   @db.VarChar(255)
  email      String   @db.VarChar(255)
  phone      String?  @db.VarChar(50)
  interest   String   @db.VarChar(255)
  message    String
  status     String   @default("unread") @db.VarChar(50)
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model hotels {
  id                String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  destination_id    String?      @db.Uuid
  name              String       @db.VarChar(255)
  slug              String       @unique @db.VarChar(255)
  hotel_type        String?      @db.VarChar(100)
  star_rating       Int?
  description       String?
  short_description String?      @db.VarChar(500)
  address           String?
  latitude          Decimal?     @db.Decimal(10, 8)
  longitude         Decimal?     @db.Decimal(11, 8)
  check_in_time     DateTime?    @db.Time(6)
  check_out_time    DateTime?    @db.Time(6)
  amenities         String[]
  room_types        Json?
  featured_image    String?      @db.VarChar(500)
  gallery_images    String[]
  contact_phone     String?      @db.VarChar(50)
  contact_email     String?      @db.VarChar(255)
  website           String?      @db.VarChar(255)
  price_per_night   Decimal?     @db.Decimal(10, 2)
  price_currency    String       @default("KES") @db.VarChar(3)
  is_active         Boolean      @default(true)
  created_at        DateTime     @default(now())
  updated_at        DateTime     @default(now())
  destinations      Destination? @relation(fields: [destination_id], references: [id])
  reviews           reviews[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model payments {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  booking_id       String?   @db.Uuid
  user_id          String?   @db.Uuid
  amount           Decimal   @db.Decimal(10, 2)
  currency         String    @default("KES") @db.VarChar(3)
  payment_method   String    @db.VarChar(50)
  transaction_id   String?   @unique @db.VarChar(255)
  status           String    @default("pending") @db.VarChar(50)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now())
  notes            String?
  payment_date     DateTime?
  receipt_url      String?   @db.VarChar(500)
  reference_number String?   @db.VarChar(100)
  bookings         bookings? @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  users            User?     @relation(fields: [user_id], references: [id])
}

model reports {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  type        String   @db.VarChar(50)
  name        String   @db.VarChar(255)
  email       String   @db.VarChar(255)
  description String
  status      String   @default("pending") @db.VarChar(50)
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model reviews {
  id                String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id           String?        @db.Uuid
  tour_package_id   String?        @db.Uuid
  rating            Int
  title             String?        @db.VarChar(255)
  verified_purchase Boolean        @default(false)
  helpful_count     Int            @default(0)
  status            String         @default("pending") @db.VarChar(50)
  created_at        DateTime       @default(now())
  updated_at        DateTime       @default(now())
  hotel_id          String?        @db.Uuid
  comment           String?
  hotels            hotels?        @relation(fields: [hotel_id], references: [id])
  tour_packages     tour_packages? @relation(fields: [tour_package_id], references: [id])
  users             User?          @relation(fields: [user_id], references: [id])
}

model tour_availability {
  id              String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tour_package_id String        @db.Uuid
  start_date      DateTime      @db.Date
  end_date        DateTime      @db.Date
  available_slots Int           @default(0)
  total_slots     Int
  special_price   Decimal?      @db.Decimal(10, 2)
  is_available    Boolean       @default(true)
  created_at      DateTime      @default(now())
  updated_at      DateTime      @default(now())
  tour_packages   tour_packages @relation(fields: [tour_package_id], references: [id], onDelete: Cascade)

  @@unique([tour_package_id, start_date])
}

model tour_itineraries {
  id                        String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tour_package_id           String        @db.Uuid
  day_number                Int
  title                     String        @db.VarChar(255)
  description               String?
  accommodation_type        String?       @db.VarChar(100)
  accommodation_name        String?       @db.VarChar(255)
  accommodation_description String?
  meals_included            String[]
  activities                String[]
  distance_traveled         Decimal?      @db.Decimal(10, 2)
  travel_time               Int?
  elevation_gain            Int?
  highlights                String[]
  images                    String[]
  created_at                DateTime      @default(now())
  updated_at                DateTime      @default(now())
  tour_packages             tour_packages @relation(fields: [tour_package_id], references: [id], onDelete: Cascade)

  @@unique([tour_package_id, day_number])
}

model tour_packages {
  id                     String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  destination_id         String?             @db.Uuid
  name                   String              @db.VarChar(255)
  slug                   String              @unique @db.VarChar(255)
  package_code           String              @unique @db.VarChar(50)
  duration_days          Int
  duration_nights        Int
  difficulty_level       String?             @db.VarChar(50)
  group_size_min         Int                 @default(1)
  group_size_max         Int                 @default(20)
  private_tour_available Boolean             @default(false)
  private_tour_price     Decimal?            @db.Decimal(10, 2)
  description            String?
  short_description      String?             @db.VarChar(500)
  highlights             String[]
  included_items         String[]
  excluded_items         String[]
  what_to_bring          String[]
  physical_rating        Int?
  cultural_rating        Int?
  wildlife_rating        Int?
  adventure_rating       Int?
  luxury_rating          Int?
  base_price             Decimal             @db.Decimal(10, 2)
  price_currency         String              @default("KES") @db.VarChar(3)
  discount_percentage    Decimal             @default(0) @db.Decimal(5, 2)
  featured_image         String?             @db.VarChar(500)
  gallery_images         String[]
  video_url              String?             @db.VarChar(500)
  cancellation_policy    String?
  terms_conditions       String?
  min_age                Int?                @default(0)
  max_age                Int?
  health_requirements    String?
  meta_title             String?             @db.VarChar(255)
  meta_description       String?
  meta_keywords          String[]
  is_featured            Boolean             @default(false)
  is_active              Boolean             @default(true)
  views_count            Int                 @default(0)
  booking_count          Int                 @default(0)
  created_at             DateTime            @default(now())
  updated_at             DateTime            @default(now())
  type                   String?             @default("tour") @db.VarChar(50)
  bookings               bookings[]
  reviews                reviews[]
  tour_availability      tour_availability[]
  tour_itineraries       tour_itineraries[]
  destinations           Destination?        @relation(fields: [destination_id], references: [id])
}

model user_activity {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String?  @db.Uuid
  action     String   @db.VarChar(100)
  ip_address String?  @db.VarChar(50)
  user_agent String?
  created_at DateTime @default(now())
  users      User?    @relation(fields: [user_id], references: [id])
}
