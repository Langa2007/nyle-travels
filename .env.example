# ============================================================
# DATABASE CONFIGURATION
# ============================================================

# Neon PostgreSQL Connection String
# Format: postgresql://user:password@host/dbname?sslmode=require
# Get this from: https://console.neon.tech
DATABASE_URL=postgresql://user:password@your-neon-project.neon.tech/nyle_travels?sslmode=require

# Alternative: Local PostgreSQL for development
# DATABASE_URL_LOCAL=postgresql://user:password@localhost:5432/nyle_travels

# Alternative: Neon-specific variable (checked first in config/db.js)
# DATABASE_URL_NEON=postgresql://user:password@your-neon-project.neon.tech/nyle_travels?sslmode=require

# ============================================================
# ENVIRONMENT
# ============================================================
NODE_ENV=development

# ============================================================
# API & SERVER CONFIGURATION
# ============================================================
PORT=3000
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# ============================================================
# JWT & AUTHENTICATION
# ============================================================
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_REFRESH_EXPIRE=30d

# ============================================================
# GOOGLE OAUTH
# ============================================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ============================================================
# EMAIL CONFIGURATION (Nodemailer)
# ============================================================
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@nyletravel.com
SMTP_FROM_NAME=Nyle Travel

# ============================================================
# PAYMENT GATEWAY (Stripe/M-Pesa)
# ============================================================
STRIPE_PUBLIC_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx
M_PESA_CONSUMER_KEY=your_m_pesa_key
M_PESA_CONSUMER_SECRET=your_m_pesa_secret

# ============================================================
# FILE UPLOAD (Cloudinary)
# ============================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================================
# ADMIN SETTINGS
# ============================================================
ADMIN_EMAIL=admin@nyletravel.com
ADMIN_PASSWORD=secure_admin_password

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=debug
DEBUG=nyle:*

# ============================================================
# SESSION/COOKIES
# ============================================================
SESSION_SECRET=your_session_secret_change_in_production
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=Lax

# ============================================================
# CORS CONFIGURATION
# ============================================================
CORS_ORIGIN=http://localhost:3001,http://localhost:3000

# ============================================================
# FEATURE FLAGS
# ============================================================
ENABLE_EMAIL_VERIFICATION=true
ENABLE_TWO_FACTOR_AUTH=true
ENABLE_GOOGLE_LOGIN=true
ENABLE_PAYMENT_PROCESSING=true

# ============================================================
# FRONTEND ENVIRONMENT (frontend/.env.local)
# ============================================================
# NEXT_PUBLIC_API_URL=http://localhost:3000
# NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token
# DATABASE_URL=postgresql://user:password@your-neon-project.neon.tech/nyle_travels?sslmode=require
